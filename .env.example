# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=super_disparador
DB_USER=root
DB_PASS=

# Evolution API
EVOLUTION_API_URL=https://your-evolution-api-url.com
EVOLUTION_API_TOKEN=your_evolution_token

# OpenAI
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4.1

# Supabase (optional)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=your_supabase_secret

# Vercel
VERCEL_TOKEN=your_vercel_token

# App
APP_URL=http://localhost:8000
APP_ENV=development
APP_NAME="Super Disparador AZ"
